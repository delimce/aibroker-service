[
  {
    "label": "Maven: compile",
    "command": "./mvnw",
    "args": ["clean", "compile"],
    "cwd": "$ZED_WORKTREE_ROOT",
    "use_new_terminal": false,
    "allow_concurrent_runs": false,
    "reveal": "always",
    "hide": "never",
  },
  {
    "label": "Maven: install",
    "command": "./mvnw",
    "args": ["clean", "install"],
    "cwd": "$ZED_WORKTREE_ROOT",
    "use_new_terminal": false,
    "allow_concurrent_runs": false,
    "reveal": "always",
    "hide": "never",
  },
  {
    "label": "Maven: clean",
    "command": "./mvnw",
    "args": ["clean"],
    "cwd": "$ZED_WORKTREE_ROOT",
    "use_new_terminal": false,
    "allow_concurrent_runs": false,
    "reveal": "always",
    "hide": "always",
  },
  {
    "label": "Maven: test",
    "command": "./mvnw",
    "args": ["clean", "test"],
    "cwd": "$ZED_WORKTREE_ROOT",
    "use_new_terminal": false,
    "allow_concurrent_runs": false,
    "reveal": "always",
    "hide": "never",
  },
  {
    "label": "Maven: package skip tests",
    "command": "./mvnw",
    "args": ["clean", "package", "-DskipTests"],
    "cwd": "$ZED_WORKTREE_ROOT",
    "use_new_terminal": false,
    "allow_concurrent_runs": false,
    "reveal": "always",
    "hide": "always",
  },
  {
    "label": "Maven: run",
    "command": "./mvnw",
    "args": ["clean", "spring-boot:run"],
    "cwd": "$ZED_WORKTREE_ROOT",
    "use_new_terminal": true,
    "allow_concurrent_runs": false,
    "reveal": "always",
    "hide": "never",
  },
  {
    "label": "Maven: run debug",
    "command": "./mvnw",
    "args": [
      "clean",
      "spring-boot:run",
      "-Dspring-boot.run.jvmArguments=-agentlib:jdwp=transport=dt_socket,server=y,suspend=y,address=*:5005",
    ],
    "cwd": "$ZED_WORKTREE_ROOT",
    "use_new_terminal": true,
    "allow_concurrent_runs": false,
    "reveal": "always",
    "hide": "never",
  },
]
